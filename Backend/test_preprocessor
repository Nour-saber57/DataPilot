import pandas as pd
import numpy as np

from preprocessor import (
    clean_column_names,
    validate_data,
    handle_outliers_iqr,
    identify_feature_types,
    split_data,
    create_preprocessing_pipeline,
)

print("=" * 60)
print("PREPROCESSOR TEST")
print("=" * 60)

np.random.seed(42)
n_samples = 200

sample_data = {
    "Age ": np.random.randint(18, 80, n_samples),
    "Income": np.random.randint(20000, 150000, n_samples),
    "Credit Score": np.random.randint(300, 850, n_samples),
    "Employment Years": np.random.randint(0, 40, n_samples),
    "Marital Status": np.random.choice(
        ["Single", "Married", "Divorced"],
        n_samples,
    ),
    "Education": np.random.choice(
        ["High School", "Bachelor", "Master"],
        n_samples,
    ),
    "Loan Approved": np.random.choice([0, 1], n_samples),
}

df = pd.DataFrame(sample_data)

df = pd.concat([df, df.iloc[[0]]], ignore_index=True)
df.loc[5, "Income"] = 10000000

target = "Loan Approved"

print("\nOriginal Dataset")
print(df.head())
print(f"\nShape: {df.shape}")

print("\n" + "=" * 60)
print("TEST 1 : clean_column_names()")
print("=" * 60)

df = clean_column_names(df)
target = target.replace(" ", "_")

print(df.columns.tolist())

print("\n" + "=" * 60)
print("TEST 2 : validate_data()")
print("=" * 60)

try:
    validate_data(df, target)
    print("✓ Validation Passed")
except Exception as e:
    print(f"✗ Validation Failed: {e}")

print("\n" + "=" * 60)
print("TEST 3 : handle_outliers_iqr()")
print("=" * 60)

numeric_cols = [
    "Age",
    "Income",
    "Credit_Score",
    "Employment_Years",
]

before = df["Income"].max()

df = handle_outliers_iqr(df, numeric_cols)

after = df["Income"].max()

print(f"Income Max Before: {before}")
print(f"Income Max After : {after}")

print("\n" + "=" * 60)
print("TEST 4 : identify_feature_types()")
print("=" * 60)

numeric_cols, ohe_cols, ord_cols = identify_feature_types(
    df,
    target,
    ordinal_cols=["Education"],
)

print("Numeric Columns:", numeric_cols)
print("OneHot Columns:", ohe_cols)
print("Ordinal Columns:", ord_cols)

print("\n" + "=" * 60)
print("TEST 5 : split_data()")
print("=" * 60)

X_train, X_test, y_train, y_test = split_data(
    df,
    target,
)

print(f"X_train: {X_train.shape}")
print(f"X_test : {X_test.shape}")
print(f"y_train: {y_train.shape}")
print(f"y_test : {y_test.shape}")

print("\n" + "=" * 60)
print("TEST 6 : create_preprocessing_pipeline()")
print("=" * 60)

try:
    pipeline = create_preprocessing_pipeline(
        df,
        target,
        ordinal_cols=["Education"],
    )

    print("✓ Pipeline Created")

    X_train_processed = pipeline.fit_transform(X_train)
    X_test_processed = pipeline.transform(X_test)

    print(f"Original Train Shape : {X_train.shape}")
    print(f"Processed Train Shape: {X_train_processed.shape}")

    print(f"Original Test Shape  : {X_test.shape}")
    print(f"Processed Test Shape : {X_test_processed.shape}")

    print("✓ Pipeline Working Correctly")

except Exception as e:
    print(f"Pipeline Error: {e}")
    import traceback
    traceback.print_exc()

print("\n" + "=" * 60)
print("TEST SUMMARY")
print("=" * 60)

print("✓ clean_column_names()")
print("✓ validate_data()")
print("✓ handle_outliers_iqr()")
print("✓ identify_feature_types()")
print("✓ split_data()")
print("✓ create_preprocessing_pipeline()")

print("\nAll preprocessing tests completed successfully.")